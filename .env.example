# ── ExamRoll backend environment ─────────────────────────────────────────────
# Copy to .env for local dev. In production (Render), set these in the
# dashboard's Environment tab — NEVER commit real values.

# Groq API key (required for AI classification; app falls back to rule-based
# extraction without it). Get one at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# SQLite path — resolves relative to backend/ (where uvicorn runs).
# NOTE (free-tier hosting): the disk is ephemeral — the DB, uploads, and
# generated Excel files may be wiped on restart/sleep. Acceptable for the
# pilot; Phase 2 moves to hosted Postgres + object storage.
# If the host's app dir is read-only, use an absolute /tmp path instead:
#   DATABASE_URL=sqlite+aiosqlite:////tmp/examroll/examroll.db
DATABASE_URL=sqlite+aiosqlite:///./examroll.db

# Upload/output directory — created automatically on startup if missing.
# On a read-only host dir, use e.g. UPLOAD_DIR=/tmp/examroll/uploads
UPLOAD_DIR=./uploads

MAX_FILE_SIZE_MB=50

# Allowed browser origins, comma-separated (JSON array form also accepted).
# Local dev:   http://localhost:5173
# Production:  add the deployed frontend origin, e.g.
#   CORS_ORIGINS=http://localhost:5173,https://examroll.pages.dev
CORS_ORIGINS=http://localhost:5173

APP_ENV=development
LOG_LEVEL=INFO
