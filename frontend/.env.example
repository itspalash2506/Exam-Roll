# Backend origin for deployed builds (Cloudflare Pages / Vercel).
# Example: VITE_API_BASE_URL=https://examroll-api.onrender.com
#
# Leave UNSET for local development — the Vite dev server proxies /api and /ws
# to http://localhost:8000 (see vite.config.js), so no env file is needed locally.
#
# The WebSocket URL is derived from this automatically (http→ws, https→wss)
# in src/api/client.js — do not configure it separately.
#
# NOTE: Vite env vars are baked in at BUILD time. Set this in the hosting
# provider's build settings (Cloudflare Pages / Vercel dashboard), not at runtime.
VITE_API_BASE_URL=
